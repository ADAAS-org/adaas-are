{
  "name": "@adaas/are",
  "version": "0.0.8",
  "description": "A-Concept Rendering Engine (ARE) is a powerful rendering engine designed to work seamlessly with the A-Concept framework. It provides developers with the tools and capabilities needed to create dynamic and interactive user interfaces for web applications.",
  "keywords": [
    "a-concept",
    "a-frame",
    "a-utils",
    "rendering-engine",
    "web-components",
    "virtual-dom",
    "reactivity-system",
    "template-syntax",
    "lifecycle-management",
    "event-handling",
    "state-management",
    "scene-graph",
    "instruction-set",
    "are-engine"
  ],
  "license": "Apache-2.0",
  "author": {
    "name": "ADAAS YAZILIM LİMİTED ŞİRKETİ",
    "email": "contact-us@adaas.org"
  },
  "homepage": "https://github.com/ADAAS-org/adaas-are#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ADAAS-org/adaas-are.git"
  },
  "bugs": {
    "url": "https://github.com/ADAAS-org/adaas-are/issues"
  },
  "exports": {
    ".": {
      "browser": {
        "types": "./dist/browser/index.d.mts",
        "import": "./dist/browser/index.mjs"
      },
      "node": {
        "types": "./dist/node/index.d.ts",
        "import": "./dist/node/index.mjs",
        "require": "./dist/node/index.cjs"
      },
      "default": {
        "types": "./dist/node/index.d.ts",
        "import": "./dist/node/index.mjs",
        "require": "./dist/node/index.cjs"
      }
    },
    "./helpers/*": {
      "node": {
        "types": "./dist/node/helpers/*.d.ts",
        "import": "./dist/node/helpers/*.mjs",
        "require": "./dist/node/helpers/*.js"
      }
    },
    "./constants/*": {
      "node": {
        "types": "./dist/node/constants/*.d.ts",
        "import": "./dist/node/constants/*.mjs",
        "require": "./dist/node/constants/*.js"
      }
    },
    "./attribute/*": {
      "node": {
        "types": "./dist/node/lib/AreAttribute/*.d.ts",
        "import": "./dist/node/lib/AreAttribute/*.mjs",
        "require": "./dist/node/lib/AreAttribute/*.js"
      }
    },
    "./compiler/*": {
      "node": {
        "types": "./dist/node/lib/AreCompiler/*.d.ts",
        "import": "./dist/node/lib/AreCompiler/*.mjs",
        "require": "./dist/node/lib/AreCompiler/*.js"
      }
    },
    "./component/*": {
      "node": {
        "types": "./dist/node/lib/AreComponent/*.d.ts",
        "import": "./dist/node/lib/AreComponent/*.mjs",
        "require": "./dist/node/lib/AreComponent/*.js"
      }
    },
    "./engine/*": {
      "node": {
        "types": "./dist/node/lib/AreEngine/*.d.ts",
        "import": "./dist/node/lib/AreEngine/*.mjs",
        "require": "./dist/node/lib/AreEngine/*.js"
      }
    },
    "./event/*": {
      "node": {
        "types": "./dist/node/lib/AreEvent/*.d.ts",
        "import": "./dist/node/lib/AreEvent/*.mjs",
        "require": "./dist/node/lib/AreEvent/*.js"
      }
    },
    "./instruction/*": {
      "node": {
        "types": "./dist/node/lib/AreInstruction/*.d.ts",
        "import": "./dist/node/lib/AreInstruction/*.mjs",
        "require": "./dist/node/lib/AreInstruction/*.js"
      }
    },
    "./interpreter/*": {
      "node": {
        "types": "./dist/node/lib/AreInterpreter/*.d.ts",
        "import": "./dist/node/lib/AreInterpreter/*.mjs",
        "require": "./dist/node/lib/AreInterpreter/*.js"
      }
    },
    "./lifecycle/*": {
      "node": {
        "types": "./dist/node/lib/AreLifecycle/*.d.ts",
        "import": "./dist/node/lib/AreLifecycle/*.mjs",
        "require": "./dist/node/lib/AreLifecycle/*.js"
      }
    },
    "./loader/*": {
      "node": {
        "types": "./dist/node/lib/AreLoader/*.d.ts",
        "import": "./dist/node/lib/AreLoader/*.mjs",
        "require": "./dist/node/lib/AreLoader/*.js"
      }
    },
    "./node/*": {
      "node": {
        "types": "./dist/node/lib/AreNode/*.d.ts",
        "import": "./dist/node/lib/AreNode/*.mjs",
        "require": "./dist/node/lib/AreNode/*.js"
      }
    },
    "./scene/*": {
      "node": {
        "types": "./dist/node/lib/AreScene/*.d.ts",
        "import": "./dist/node/lib/AreScene/*.mjs",
        "require": "./dist/node/lib/AreScene/*.js"
      }
    },
    "./signals/*": {
      "node": {
        "types": "./dist/node/lib/AreSignals/*.d.ts",
        "import": "./dist/node/lib/AreSignals/*.mjs",
        "require": "./dist/node/lib/AreSignals/*.js"
      }
    },
    "./store/*": {
      "node": {
        "types": "./dist/node/lib/AreStore/*.d.ts",
        "import": "./dist/node/lib/AreStore/*.mjs",
        "require": "./dist/node/lib/AreStore/*.js"
      }
    },
    "./syntax/*": {
      "node": {
        "types": "./dist/node/lib/AreSyntax/*.d.ts",
        "import": "./dist/node/lib/AreSyntax/*.mjs",
        "require": "./dist/node/lib/AreSyntax/*.js"
      }
    },
    "./tokenizer/*": {
      "node": {
        "types": "./dist/node/lib/AreTokenizer/*.d.ts",
        "import": "./dist/node/lib/AreTokenizer/*.mjs",
        "require": "./dist/node/lib/AreTokenizer/*.js"
      }
    },
    "./transformer/*": {
      "node": {
        "types": "./dist/node/lib/AreTransformer/*.d.ts",
        "import": "./dist/node/lib/AreTransformer/*.mjs",
        "require": "./dist/node/lib/AreTransformer/*.js"
      }
    },
    "./watcher/*": {
      "node": {
        "types": "./dist/node/lib/AreWatcher/*.d.ts",
        "import": "./dist/node/lib/AreWatcher/*.mjs",
        "require": "./dist/node/lib/AreWatcher/*.js"
      }
    }
  },
  "sideEffects": false,
  "nodemonConfig": {
    "ignore": [
      "**/*.test.ts",
      "**/*.spec.ts",
      ".git",
      "node_modules",
      "**/dist/**"
    ],
    "watch": [
      "examples",
      "src"
    ],
    "exec": "node -r tsconfig-paths/register -r ts-node/register ",
    "ext": "ts, js"
  },
  "scripts": {
    "test": "jest",
    "test:test": "nodemon ./src/test/app.ts",
    "release": "npm test && npm run build && git add . && git commit -m \"chore: prepare release $npm_package_version\" && npm version patch",
    "preversion": "",
    "version": "git add -A",
    "postversion": "git push --no-verify && git push --tags --no-verify && npm publish --access public && echo \"\\n======Version Published Successfully=====\\n\"",
    "echo-version": "echo $npm_package_version",
    "build": "tsup --config tsup.config.ts"
  },
  "dependencies": {
    "@adaas/a-concept": "^0.3.13",
    "@adaas/a-frame": "^0.0.22",
    "@adaas/a-utils": "^0.3.18"
  },
  "devDependencies": {
    "@types/chai": "^4.3.14",
    "@types/jest": "^29.5.12",
    "@types/mocha": "^10.0.6",
    "@types/node": "^24.9.1",
    "axios": "^1.7.2",
    "chai": "^5.1.0",
    "dotenv": "^16.4.5",
    "jest": "^29.7.0",
    "mocha": "^10.4.0",
    "nodemon": "^3.1.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tscpaths": "^0.0.9",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "directories": {
    "doc": "docs",
    "test": "tests"
  }
}
